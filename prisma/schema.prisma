generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TasteAppUser {
  id                 String                 @id @default(uuid()) @db.Uuid
  displayName        String?
  primaryEmail       String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  externalIdentities ExternalAuthIdentity[]

  @@map("tasteapp_users")
}

model ExternalAuthIdentity {
  id              String       @id @default(uuid()) @db.Uuid
  tasteAppUserId  String       @db.Uuid
  provider        String
  providerSubject String
  email           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  tasteAppUser    TasteAppUser @relation(fields: [tasteAppUserId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([tasteAppUserId])
  @@map("external_auth_identities")
}
