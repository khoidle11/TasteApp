{
  "name": "tasteapp",
  "version": "0.0.0",
  "private": true,
  "description": "Dish-first food review app monorepo.",
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm run build:root && turbo run build",
    "build:root": "tsc -p tsconfig.build.json",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "dev": "turbo run dev --parallel",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "pnpm run lint:root && turbo run lint",
    "lint:root": "eslint src test vitest.config.ts --max-warnings=0",
    "test": "pnpm run test:root && turbo run test",
    "test:root": "vitest run",
    "typecheck": "pnpm run typecheck:root && turbo run typecheck",
    "typecheck:root": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "turbo": "^2.10.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
